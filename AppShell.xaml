<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:helpers="clr-namespace:AirIQ.Extensions"
       xmlns:local="clr-namespace:AirIQ.Views"
       xmlns:resx="clr-namespace:AirIQ.Resources.Strings"
       xmlns:controls="clr-namespace:AirIQ.Controls"
       xmlns:views="clr-namespace:AirIQ.Views.ContentViews"
       x:Class="AirIQ.AppShell"
       FlyoutBackgroundColor="{StaticResource PrimaryColor}"
       BackgroundColor="{StaticResource PrimaryColor}"
       ForegroundColor="{StaticResource White}"
       TitleColor="{StaticResource White}"
       FlyoutIsPresented="False"
       FlyoutBehavior="Disabled">

    <Shell.FlyoutBackdrop>
        <SolidColorBrush Color="#66000000"/>
    </Shell.FlyoutBackdrop>

    <Shell.Resources>
        <Style TargetType="TabBar">
            <Setter Property="Shell.TabBarForegroundColor"
                    Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Shell.TabBarTitleColor"
                    Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Shell.TabBarUnselectedColor"
                    Value="{StaticResource Gray600}"/>
        </Style>
    </Shell.Resources>

    <Shell.FlyoutContentTemplate>
        <DataTemplate>
            <views:MenuContentView/>
            <!-- FULL SCREEN FLYOUT -->
        </DataTemplate>
    </Shell.FlyoutContentTemplate>

    <!-- ============================================ -->
    <!-- AUTHENTICATION ROUTES (No TabBar) -->
    <!-- ============================================ -->

    <!-- ROUTE: loading - Initial loading/splash screen -->
    <ShellContent
        Title="Loading"
        ContentTemplate="{DataTemplate controls:LoadingIndicatorView}"
        Route="loading"
        Shell.TabBarIsVisible="False"
        Shell.FlyoutItemIsVisible="False"/>

    <!-- ROUTE: login - User authentication -->
    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate local:LoginPage}"
        Route="LoginPage"
        Shell.TabBarIsVisible="False"
        Shell.FlyoutItemIsVisible="False"/>

    <!-- ============================================ -->
    <!-- MAIN APPLICATION ROUTES (With TabBar) -->
    <!-- ============================================ -->

    <FlyoutItem>
        <ShellContent Title="Search"/>
    </FlyoutItem>

    <TabBar Route="app">
        <ShellContent Route="home"
                      Title="{x:Static resx:AppResource.Flights}"
                      ContentTemplate="{DataTemplate local:DashboardPage}"
                      Icon="flight">
            <!-- <ShellContent.Icon>
                <FontImageSource
                    FontFamily="MyFont"
                    Glyph="{x:Static helpers:FontAwesomeIcons.Plane}"
                    Size="24"/>
            </ShellContent.Icon> -->
        </ShellContent>

        <ShellContent
            Title="{x:Static resx:AppResource.Hotels}"
            ContentTemplate="{DataTemplate local:HotelsPage}">
            <ShellContent.Icon>
                <FontImageSource
                    FontFamily="MyFont"
                    Glyph="{x:Static helpers:FontAwesomeIcons.Hotel}"
                    Size="24"/>
            </ShellContent.Icon>
        </ShellContent>


        <ShellContent
            Title="{x:Static resx:AppResource.Account}"
            ContentTemplate="{DataTemplate local:AccountsPage}">
            <ShellContent.Icon>
                <FontImageSource
                    FontFamily="MyFont"
                    Glyph="{x:Static helpers:FontAwesomeIcons.UserCircle}"
                    Size="24"/>
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent
            Title="{x:Static resx:AppResource.Settings}"
            ContentTemplate="{DataTemplate local:SettingsPage}">
            <ShellContent.Icon>
                <FontImageSource
                    FontFamily="MyFont"
                    Glyph="{x:Static helpers:FontAwesomeIcons.Cog}"
                    Size="24"/>
            </ShellContent.Icon>
        </ShellContent>

    </TabBar>

</Shell>