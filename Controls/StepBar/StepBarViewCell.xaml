<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AirIQ.Controls.StepBar.StepBarViewCell"
             xmlns:converters="clr-namespace:AirIQ.Converter"
             xmlns:extensions="clr-namespace:AirIQ.Extensions"
             xmlns:models="clr-namespace:AirIQ.Models"
             x:DataType="models:StepBarModel">

    <ContentView.Resources>
        <ResourceDictionary>
            <converters:StepColorConverter x:Key="StepColorConverter"/>
            <converters:StepImageConverter x:Key="StepImageConverter"/>
        </ResourceDictionary>
    </ContentView.Resources>

    <ContentView.Content>

        <Grid HorizontalOptions="Center"
              VerticalOptions="FillAndExpand"
              x:Name="mainGrid"
              ColumnSpacing="0"
              Margin="0"
              Padding="0"
              RowDefinitions="Auto,Auto">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="ProgressColumn"
                                  Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid WidthRequest="20"
                  Grid.Column="0"
                  x:Name="trackergrid"
                  HorizontalOptions="CenterAndExpand"
                  VerticalOptions="Start"
                  Padding="0"
                  Margin="0,10,0,0"
                  RowSpacing="1"
                  ColumnSpacing="0"
                  RowDefinitions="Auto"
                  ColumnDefinitions="Auto"
                  Grid.Row="1">

                <Border StrokeShape="Ellipse"
                        HeightRequest="20"
                        WidthRequest="20"
                        Stroke="black"
                        BackgroundColor="{Binding Status,Converter={StaticResource StepColorConverter}}">

                    <Image Aspect="AspectFill"
                           Margin="4"
                           Source="{Binding Status,Converter={StaticResource StepImageConverter}}"/>

                </Border>

                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="StepTapped_Tapped"/>
                </Grid.GestureRecognizers>

            </Grid>

            <ProgressBar VerticalOptions="{OnPlatform iOS='CenterAndExpand', Android='FillAndExpand'}"
                         HorizontalOptions="FillAndExpand"
                         Margin="0,10,0,0"
                         x:Name="progress"
                         ProgressColor="#127ABF"
                         Grid.Column="1"
                         IsVisible="{Binding IsNotLast}"
                         Grid.Row="1">
                <!-- <ProgressBar.Triggers>
                    <DataTrigger TargetType="ProgressBar"
                                 Binding="{Binding IsNotLast}"
                                 Value="False">
                        <Setter Property="WidthRequest"
                                Value="0"/>
                    </DataTrigger>
                </ProgressBar.Triggers> -->
            </ProgressBar>


            <Label Text="{Binding StepName}"
                   x:Name="mainLabel"
                   VerticalOptions="Start"
                   HorizontalOptions="Start"
                   Grid.Row="0"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   MaximumWidthRequest="80"
                   LineBreakMode="TailTruncation"
                   Style="{StaticResource Label14MediumGray90Style}"/>

        </Grid>

    </ContentView.Content>
</ContentView>
