<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AirIQ.Controls.StepBarComponentView"
             xmlns:converters="clr-namespace:AirIQ.Converter">

    <ContentView.Resources>
        <ResourceDictionary>
            <converters:ProgressValueConverter x:Key="ProgressValueConverter"/>
            <converters:StepColorConverter x:Key="StepColorConverter"/>
            <converters:StepImageConverter x:Key="StepImageConverter"/>
        </ResourceDictionary>
    </ContentView.Resources>


    <Grid x:Name="Root"
          Padding="0"
          RowDefinitions="Auto,*"
          BackgroundColor="White">

        <CollectionView
            x:Name="collectionView"
            MaximumHeightRequest="60"
            HorizontalScrollBarVisibility="Never"
            HorizontalOptions="Center"
            ItemsSource="{Binding Steps, Mode=TwoWay}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal"/>
            </CollectionView.ItemsLayout>
        </CollectionView>

        <ScrollView Grid.Row="1"
                    VerticalScrollBarVisibility="Never">
            <ContentView x:Name="MainDynamicContent"/>
        </ScrollView>

    </Grid>

</ContentView>
