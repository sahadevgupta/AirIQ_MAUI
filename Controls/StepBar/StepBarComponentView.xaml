<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AirIQ.Controls.StepBarComponentView"
             xmlns:converters="clr-namespace:AirIQ.Converter">

    <ContentView.Resources>
        <ResourceDictionary>
            <converters:ProgressValueConverter x:Key="ProgressValueConverter"/>
            <converters:StepColorConverter x:Key="StepColorConverter"/>
            <converters:StepImageConverter x:Key="StepImageConverter"/>
        </ResourceDictionary>
    </ContentView.Resources>


    <Grid x:Name="StepBarGrid"
            ColumnSpacing="0"
            RowSpacing="0"
            VerticalOptions="Fill"
            HorizontalOptions="Fill">
        <CollectionView
            x:Name="collectionView"
            ItemsSource="{Binding Steps, Mode=TwoWay}"
            VerticalOptions="Fill"
            HorizontalOptions="Fill"
            HorizontalScrollBarVisibility="Never"
            BackgroundColor="Transparent"
            ItemSizingStrategy="MeasureFirstItem">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal"/>
            </CollectionView.ItemsLayout>
        </CollectionView>
    </Grid>

</ContentView>
