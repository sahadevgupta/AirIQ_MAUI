<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AirIQ.Controls.SearchView"
             x:Name="searchView">

    <Border Style="{StaticResource DefaultBorderStyle}">
        <Grid ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="10"
              HeightRequest="40">

            <Border Stroke="{StaticResource BorderColor}"
                    StrokeShape="RoundRectangle 6">
                <SearchBar Text="{Binding SearchText,Source={x:Reference searchView}}"
                           Placeholder="{Binding PlaceholderText,Source={x:Reference searchView}}"
                           SearchCommand="{Binding SearchCommand,Source={x:Reference searchView}}"/>
            </Border>

            <ImageButton Source="filter"
                         Grid.Column="1"
                         Command="{Binding FilterCommand,Source={x:Reference searchView}}"/>

            <ImageButton Source="download"
                         Grid.Column="2"
                         Command="{Binding DownloadCommand,Source={x:Reference searchView}}"/>
        </Grid>
    </Border>

</ContentView>