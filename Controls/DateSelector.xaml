<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AirIQ.Controls.DateSelector"
             xmlns:controls="clr-namespace:AirIQ.Controls"
             xmlns:ext="clr-namespace:AirIQ.Extensions">

    <Grid ColumnDefinitions="*,*,*"
          ColumnSpacing="8">

        <controls:DateChip x:Name="LeftChip"
                           Grid.Column="0"
                           ShowIcon="True">
            <controls:DateChip.Icon>
                <FontImageSource FontFamily="MyFont"
                                 Glyph="{x:Static ext:FontAwesomeIcons.ChevronLeft}"
                                 Color="Gray"/>
            </controls:DateChip.Icon>
        </controls:DateChip>

        <controls:DateChip x:Name="CenterChip"
                           Grid.Column="1"
                           ShowIcon="True"
                           Icon="Calendar"/>

        <controls:DateChip x:Name="RightChip"
                           Grid.Column="2"
                           ShowIcon="True"
                           ImageAlingment="Right">
            <controls:DateChip.Icon>
                <FontImageSource FontFamily="MyFont"
                                 Glyph="{x:Static ext:FontAwesomeIcons.ChevronRight}"
                                 Color="Gray"/>
            </controls:DateChip.Icon>
        </controls:DateChip>


    </Grid>
</ContentView>
