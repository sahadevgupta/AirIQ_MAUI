<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage
    x:Class="AirIQ.Views.FlightBookingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:AirIQ.Controls"
    xmlns:ext="clr-namespace:AirIQ.Extensions"
    xmlns:enums="clr-namespace:AirIQ.Enums"
    xmlns:helpers="clr-namespace:AirIQ.Extensions"
    xmlns:models="clr-namespace:AirIQ.Models"
    xmlns:resx="clr-namespace:AirIQ.Resources.Strings"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewmodels="clr-namespace:AirIQ.ViewModels"
    xmlns:views="clr-namespace:AirIQ.Views"
    Title="FlightBookingPage"
    x:DataType="viewmodels:FlightBookingPageViewModel">

    <views:BasePage.PageContent>

        <CollectionView ItemsSource="{Binding AdultPassengers}">
            <CollectionView.Header>
                <VerticalStackLayout Margin="10"
                                     Spacing="20">
                    <Border BackgroundColor="#E8E8E8"
                            StrokeShape="RoundRectangle 8"
                            Stroke="{StaticResource BorderColor}">

                        <Grid RowDefinitions="Auto,Auto">

                            <HorizontalStackLayout HorizontalOptions="Start"
                                                   Spacing="10"
                                                   Padding="16">
                                <Image Source="{Binding SelectedAirline.AirlineLogoUrl}"
                                       HeightRequest="40"/>

                                <Label Text="{Binding SelectedAirline.Airline}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout HorizontalOptions="End"
                                                   Padding="16"
                                                   Spacing="0">
                                <Image Source="calendar"
                                       VerticalOptions="Center"
                                       HeightRequest="24"/>

                                <Label Text="{Binding SelectedAirline.DepartureDateTime,StringFormat='{0: dd MMM, yyyy}'}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>

                            <Grid Grid.Row="1"
                                  Padding="16"
                                  ColumnDefinitions="2*,6*,2*"
                                  BackgroundColor="White">

                                <Label Grid.Row="0"
                                       VerticalTextAlignment="Center">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding SelectedAirline.DepartureTime}"
                                                  Style="{StaticResource Label20MediumOnyxStyle}"
                                                  TextColor="Black"/>
                                            <Span Text="&#10; "/>
                                            <Span Text="{Binding SelectedAirline.Origin}"
                                                  Style="{StaticResource Label14RegularGray50Style}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Grid.Row="1">

                                    <Image Source="flight_route"/>

                                    <Label HorizontalOptions="Center"
                                           VerticalTextAlignment="Center">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding SelectedAirline.TotalDuration}"
                                                      Style="{StaticResource Span12RegularGray50Style}"
                                                      FontSize="14"/>
                                                <Span Text=" | "
                                                      Style="{StaticResource Span12RegularGray50Style}"
                                                      FontSize="14"/>
                                                <Span Text="{Binding SelectedAirline.FlightRoute}"
                                                      Style="{StaticResource Span12RegularGray50Style}"
                                                      FontSize="14"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                </VerticalStackLayout>

                                <Label Grid.Row="0"
                                       Grid.Column="2"
                                       HorizontalOptions="End"
                                       VerticalTextAlignment="Center">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding SelectedAirline.ArrivalTime}"
                                                  Style="{StaticResource Label20MediumOnyxStyle}"
                                                  TextColor="Black"/>
                                            <Span Text="&#10;"/>
                                            <Span Text="{Binding SelectedAirline.Destination}"
                                                  Style="{StaticResource Label14RegularGray50Style}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                            </Grid>


                        </Grid>


                    </Border>
                    <Label Text="Travellers DEtails"
                           Style="{StaticResource Label18StyleBold}"
                           TextColor="{StaticResource PrimaryColor}"
                           Grid.Row="2"/>
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Passenger">
                    <Border Margin="10"
                            Stroke="{StaticResource BorderColor}"
                            BackgroundColor="{StaticResource Gray10}"
                            StrokeShape="RoundRectangle 8">
                        <toolkit:Expander IsExpanded="{Binding IsSectionOpen, Mode=TwoWay}">
                            <toolkit:Expander.Header>

                                <Grid>
                                    <Label VerticalTextAlignment="Center"
                                           Padding="16">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="Adult #1"
                                                      Style="{StaticResource Label20MediumOnyxStyle}"
                                                      TextColor="Black"/>
                                                <Span Text="&#10;"/>
                                                <Span Text="{x:Static resx:AppResource.DetailsProvided}"
                                                      Style="{StaticResource Label14RegularGray50Style}"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                    <Image HorizontalOptions="End"
                                           VerticalOptions="Center"
                                           Margin="0,0,16,0">
                                        <Image.Source>
                                            <FontImageSource FontFamily="MyFont"
                                                             Glyph="{x:Static ext:FontAwesomeIcons.ChevronDown}"
                                                             Size="20"
                                                             Color="Black"/>
                                        </Image.Source>
                                        <Image.Triggers>
                                            <DataTrigger TargetType="Image"
                                                         Binding="{Binding IsSectionOpen}"
                                                         Value="False">
                                                <Setter Property="Rotation"
                                                        Value="270"/>
                                            </DataTrigger>
                                        </Image.Triggers>
                                    </Image>

                                </Grid>
                            </toolkit:Expander.Header>

                            <Grid BackgroundColor="White"
                                  Padding="16"
                                  ColumnDefinitions="*,*"
                                  ColumnSpacing="10"
                                  RowDefinitions="Auto,Auto,Auto">

                                <controls:ExtendedDropdown Title="{x:Static resx:AppResource.Adult}"
                                                           HasPadding="True"
                                                           SelectedItem="{Binding SelectedPassengerType}">
                                    <controls:ExtendedDropdown.ItemsSource>
                                        <x:Array Type="{x:Type x:String}">
                                            <x:String>Adult</x:String>
                                            <x:String>Child</x:String>
                                        </x:Array>
                                    </controls:ExtendedDropdown.ItemsSource>
                                </controls:ExtendedDropdown>

                                <controls:ExtendedDropdown
                                    Title="{x:Static resx:AppResource.Title}"
                                    Grid.Column="1"
                                    HasPadding="True"
                                    ItemsSource="{Binding BindingContext.PassengerTitles, Source={x:Reference passengerList}}"
                                    PlaceholderText="{x:Static resx:AppResource.Title}"
                                    SelectedItem="{Binding SelectedTitle}"/>

                                <controls:ExtendedEntry Title="{x:Static resx:AppResource.FirstName}"
                                                        Grid.Row="1"
                                                        Grid.ColumnSpan="2"
                                                        PlaceholderText="{x:Static resx:AppResource.FirstName}"
                                                        Text="{Binding FirstName}"/>
                                <controls:ExtendedEntry Title="{x:Static resx:AppResource.LastName}"
                                                        Grid.Row="2"
                                                        Grid.ColumnSpan="2"
                                                        PlaceholderText="{x:Static resx:AppResource.LastName}"
                                                        Text="{Binding LastName}"/>
                            </Grid>
                        </toolkit:Expander>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </views:BasePage.PageContent>

</views:BasePage>
