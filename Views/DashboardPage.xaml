<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage
  x:Class="AirIQ.Views.DashboardPage"
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:controls="clr-namespace:AirIQ.Controls"
  xmlns:helpers="clr-namespace:AirIQ.Constants"
  xmlns:resx="clr-namespace:AirIQ.Resources.Strings"
  xmlns:template="clr-namespace:AirIQ.Views.ContentViews"
  xmlns:viewmodel="clr-namespace:AirIQ.ViewModels"
  xmlns:views="clr-namespace:AirIQ.Views"
  x:Name="thisPage"
  x:DataType="viewmodel:DashboardPageViewModel"
  IsNavBarVisible="False">

  <views:BasePage.PageContent>

    <AbsoluteLayout HorizontalOptions="Fill"
                    VerticalOptions="Fill">

      <Image Source="navigation"/>

      <Grid ColumnDefinitions="Auto,Auto"
            RowDefinitions="Auto,Auto"
            Margin="16"
            ColumnSpacing="16"
            RowSpacing="9">
        <Image Source="menu"
               HorizontalOptions="Start"
               VerticalOptions="Center">
          <Image.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding OpenMenuCommand}"/>
          </Image.GestureRecognizers>
        </Image>

        <Label VerticalOptions="Center"
               Grid.Column="1">
          <Label.FormattedText>
            <FormattedString>
              <FormattedString.Spans>
                <Span Text="Hello"
                      Style="{StaticResource Label16Bold}"
                      TextColor="Black"/>
                <Span Text=" "/>
                <Span Text="{Binding CurrentUser.ContactPerson}"
                      Style="{StaticResource Label16Bold}"
                      TextColor="Black"/>
                <Span Text="! "
                      Style="{StaticResource Label16Bold}"
                      TextColor="Black"/>
              </FormattedString.Spans>
            </FormattedString>
          </Label.FormattedText>
        </Label>

        <Label LineBreakMode="WordWrap"
               Grid.Row="1"
               Grid.Column="1"
               VerticalOptions="Center">
          <Label.FormattedText>
            <FormattedString>
              <Span Text="Book your flight with &#10;"
                    Style="{StaticResource Label32Bold}"/>
              <Span Text="Air"
                    TextColor="{StaticResource PrimaryColor}"
                    Style="{StaticResource Label32Bold}"/>
              <Span Text="IQ"
                    TextColor="red"
                    Style="{StaticResource Label32Bold}"/>
            </FormattedString>
          </Label.FormattedText>
        </Label>

      </Grid>


      <Image Source="notifications"
             AbsoluteLayout.LayoutBounds="1, 0, AutoSize, AutoSize"
             AbsoluteLayout.LayoutFlags="PositionProportional"
             Margin="16"
             HorizontalOptions="End"
             VerticalOptions="Start">
        <Image.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding OpenMenuCommand}"/>
        </Image.GestureRecognizers>
      </Image>

      <Grid AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="HeightProportional,WidthProportional"
            Margin="16,170,16,0"
            RowDefinitions="Auto,Auto,Auto,Auto,Auto">

        <controls:EntryWithTitleImage MaximumHeightRequest="100"
                                      Icon="flight_departure"
                                      Title="{x:Static resx:AppResource.From}"
                                      ItemsSource="{Binding SourceAirports}"
                                      PlaceholderText="{x:Static resx:AppResource.SearchDepartureAirport}"
                                      SelectedItem="{Binding SelectedSourceAirport}"
                                      TextChangeCommand="{Binding SearchSourceAirportsCommand}"
                                      DisplayMemberPath="OriginRoute"
                                      CanEdit="True"/>

        <controls:EntryWithTitleImage MaximumHeightRequest="100"
                                      Grid.Row="1"
                                      Icon="flight_arrival"
                                      Title="{x:Static resx:AppResource.To}"
                                      ItemsSource="{Binding DestinationAirports}"
                                      PlaceholderText="{x:Static resx:AppResource.SearchDestinationAirport}"
                                      SelectedItem="{Binding SelectedDestinationAirport}"
                                      TextChangeCommand="{Binding SearchDestinationAirportsCommand}"
                                      DisplayMemberPath="DestinationRoute"
                                      CanEdit="True"/>

        <Border Padding="16,15"
                Grid.Row="2"
                Margin="0,12,0,0"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 8"
                StrokeThickness="1"
                Stroke="#E5E5E5">
          <Grid ColumnDefinitions="Auto, *"
                ColumnSpacing="16"
                RowDefinitions="Auto, Auto">
            <Image Source="calendar"
                   Grid.RowSpan="2"
                   VerticalOptions="Center"/>

            <Label Text="Departure"
                   Grid.Column="1"
                   Style="{StaticResource Label14RegularGray50Style}"
                   VerticalOptions="Center"/>

            <!--Custom Dropdown-->
            <!-- <local:CustomDropdown x:Name="dropdown"
                                  AutomationId="dropdownview"
                                  CanEdit="{Binding CanEdit,Source={x:Reference thisControl}}"
                                  ItemSource="{Binding ItemsSource,Source={x:Reference thisControl}}"
                                  InputViewStyle="{Binding InputViewStyle,Source={x:Reference thisControl}}"
                                  PlaceholderText="{Binding PlaceholderText,Source={x:Reference thisControl}}"
                                  SelectedItem="{Binding SelectedItem,Source={x:Reference thisControl}}"
                                  DisplayMemberPath="{Binding DisplayMemberPath,Source={x:Reference thisControl}}"
                                  TextChanged="DropdownTextChanged"
                                  Grid.Row="1"
                                  Grid.Column="1"/> -->
          </Grid>

        </Border>

        <controls:EntryWithTitleImage MaximumHeightRequest="100"
                                      Margin="0,12,0,0"
                                      Grid.Row="3"
                                      Icon="person"
                                      Title="{x:Static resx:AppResource.To}"
                                      ItemsSource="{Binding DestinationAirports}"
                                      PlaceholderText="{x:Static resx:AppResource.SearchDestinationAirport}"
                                      SelectedItem="{Binding SelectedDestinationAirport}"
                                      TextChangeCommand="{Binding SearchDestinationAirportsCommand}"
                                      DisplayMemberPath="DestinationRoute"
                                      CanEdit="True"/>

        <Button Style="{StaticResource ButtonCorneredStyle}"
                Grid.Row="4"
                Margin="0,24,0,0"
                Text="{x:Static resx:AppResource.SearchFlights}"
                Command="{Binding SearchFlightsCommand}"/>




        <ImageButton Source="swap"
                     HorizontalOptions="End"
                     Grid.RowSpan="2"
                     Margin="0,0,20,0"
                     BackgroundColor="Transparent"
                     Command="{Binding SwapSourceDestinationCommand}"/>

      </Grid>

    </AbsoluteLayout>

