<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage
    x:Class="AirIQ.Views.FlightsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:AirIQ.Controls"
    xmlns:ext="clr-namespace:AirIQ.Extensions"
    xmlns:models="clr-namespace:AirIQ.Models"
    xmlns:resx="clr-namespace:AirIQ.Resources.Strings"
    xmlns:viewmodels="clr-namespace:AirIQ.ViewModels"
    xmlns:views="clr-namespace:AirIQ.Views"
    PageTitle="Select Flight"
    x:DataType="viewmodels:FlightsPageViewModel">

    <views:BasePage.PageContent>

        <Grid Padding="0"
              RowSpacing="0"
              BackgroundColor="{StaticResource BackgroundColor}"
              RowDefinitions="Auto, *">

            <Border Padding="16"
                    StrokeThickness="0"
                    BackgroundColor="White">

                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="10"
                      RowSpacing="12"
                      RowDefinitions="Auto,Auto,Auto">
                    <HorizontalStackLayout Spacing="16"
                                           Grid.ColumnSpan="3">
                        <Label>
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding FlightSearchRequest.Origin}"
                                          Style="{StaticResource Span16RegularGray50Style}"
                                          FontFamily="RobotoBold"
                                          TextColor="{StaticResource Gray90}"/>
                                    <Span Text="&#10;"/>
                                    <Span Text="{Binding FlightSearchRequest.OriginAirportName}"
                                          Style="{StaticResource Span12RegularGray50Style}"/>

                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <Image>
                            <Image.Source>
                                <FontImageSource FontFamily="MyFont"
                                                 Glyph="{x:Static ext:FontAwesomeIcons.LongArrowAltRight}"
                                                 Color="{StaticResource Gray90}"/>
                            </Image.Source>
                        </Image>

                        <Label>
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding FlightSearchRequest.Destination}"
                                          Style="{StaticResource Span16RegularGray50Style}"
                                          FontFamily="RobotoBold"
                                          TextColor="{StaticResource Gray90}"/>
                                    <Span Text="&#10;"/>
                                    <Span Text="{Binding FlightSearchRequest.DestinationAirportName}"
                                          Style="{StaticResource Span12RegularGray50Style}"/>

                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </HorizontalStackLayout>

                    <controls:DateSelector SelectedDate="{Binding SelectedTravelDate}"
                                           Grid.Row="1"
                                           Grid.ColumnSpan="3"/>

                    <Button Text="AIR IQ"
                            Grid.Row="2"
                            Grid.Column="0"
                            Style="{StaticResource SmallBorderButtonStyle}"/>

                    <Button Text="MARKETPLACE"
                            Grid.Row="2"
                            HorizontalOptions="Start"
                            Style="{StaticResource SmallBorderButtonStyle}"
                            Grid.Column="1"/>


                    <Label Text="{Binding AvailableFlights.Count,TargetNullValue=0,StringFormat='{0} Flights'}"
                           Style="{StaticResource Label16Bold}"
                           Grid.Row="2"
                           Grid.Column="2"
                           VerticalOptions="Center"
                           HorizontalOptions="End"/>

                </Grid>

            </Border>

            <CollectionView ItemSizingStrategy="MeasureFirstItem"
                            Margin="0,10,0,10"
                            x:Name="flightsCollectionView"
                            Grid.Row="1"
                            ItemsSource="{Binding AvailableFlights}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout ItemSpacing="10"
                                       Orientation="Vertical"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Flight">
                        <Border Margin="10,0"
                                Style="{StaticResource DefaultBorderStyle}">
                            <Grid ColumnDefinitions="3*,4*,3*"
                                  x:Name="mainView"
                                  RowSpacing="10"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto">

                                <HorizontalStackLayout Spacing="10">

                                    <Image Source="{Binding AirlineLogoUrl}"
                                           Grid.Column="0"
                                           HeightRequest="50"
                                           Grid.Row="0"/>

                                    <Label
                                        VerticalTextAlignment="Center">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding Airline}"
                                                      Style="{StaticResource Label14MediumGray90Style}"
                                                      FontSize="16"/>
                                                <Span Text="&#10;"/>
                                                <Span Text="{Binding FlightNumber}"
                                                      Style="{StaticResource Span12RegularGray50Style}"
                                                      FontSize="16"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>


                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Column="1"
                                                       Grid.ColumnSpan="2"
                                                       VerticalOptions="Center"
                                                       Spacing="4"
                                                       HorizontalOptions="End">


                                    <Image Source="luggag"
                                           MinimumHeightRequest="20"
                                           MinimumWidthRequest="20"/>

                                    <Label LineBreakMode="WordWrap"
                                           VerticalOptions="Center">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding HandLuggage}"
                                                      Style="{StaticResource Label14Bold}"/>
                                                <Span Text=", "
                                                      Style="{StaticResource Label14Bold}"/>
                                                <Span Text="{Binding CabinBaggage}"
                                                      Style="{StaticResource Label14Bold}"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </HorizontalStackLayout>

                                <Label Grid.Row="1"
                                       VerticalTextAlignment="Center">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding DepartureTime}"
                                                  Style="{StaticResource Label20MediumOnyxStyle}"
                                                  TextColor="Black"/>
                                            <Span Text="&#10; "/>
                                            <Span Text="{Binding DepartureDateTime, StringFormat='{0:dd MMM}'}"
                                                  Style="{StaticResource Label14RegularGray50Style}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Grid.Row="1">

                                    <Image Source="flight_route"/>

                                    <Label Grid.Row="1"
                                           Grid.Column="2"
                                           HorizontalOptions="Center"
                                           VerticalTextAlignment="Center">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding TotalDuration}"
                                                      Style="{StaticResource Span12RegularGray50Style}"
                                                      FontSize="14"/>
                                                <Span Text=" | "
                                                      Style="{StaticResource Span12RegularGray50Style}"
                                                      FontSize="14"/>
                                                <Span Text="{Binding FlightRoute}"
                                                      Style="{StaticResource Span12RegularGray50Style}"
                                                      FontSize="14"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                </VerticalStackLayout>


                                <Label Grid.Row="1"
                                       Grid.Column="2"
                                       HorizontalOptions="End"
                                       VerticalTextAlignment="Center">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding ArrivalTime}"
                                                  Style="{StaticResource Label20MediumOnyxStyle}"
                                                  TextColor="Black"/>
                                            <Span Text="&#10;"/>
                                            <Span Text="{Binding ArrivalDateTime, StringFormat='{0:dd MMM}'}"
                                                  Style="{StaticResource Label14RegularGray50Style}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <Line  StrokeDashArray="3,3"
                                       X1="0"
                                       Y1="0"
                                       X2="{Binding Source={x:Reference mainView}, Path=Width}"
                                       Y2="0"
                                       Stroke="#B9B9B9"
                                       Grid.ColumnSpan="3"
                                       Grid.Row="2"/>

                                <Label Grid.Row="3"
                                       VerticalOptions="Center"
                                       Grid.ColumnSpan="2">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{x:Static resx:AppResource.TourCode}"/>
                                            <Span Text="  "/>
                                            <Span Text="AQP1550"
                                                  Style="{StaticResource Span16BoldPrimaryStyle}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <Button Text="{Binding Pax, StringFormat='Copy {0} seats'}"
                                        Command="{Binding BindingContext.CopyFlightDetailCommand,Source={x:Reference flightsCollectionView}}"
                                        Grid.Row="3"
                                        BorderColor="{StaticResource Gray30}"
                                        BorderWidth="1"
                                        Grid.Column="1"
                                        FontSize="12"
                                        Grid.ColumnSpan="2"
                                        BackgroundColor="{StaticResource Gray10}"
                                        ImageSource="content_copy"
                                        HorizontalOptions="End"
                                        TextColor="Black"
                                        Padding="12,8"
                                        MinimumHeightRequest="0"
                                        MinimumWidthRequest="0"/>


                                <Button Grid.Row="4"
                                        Grid.ColumnSpan="3"
                                        Margin="0,8,0,0"
                                        Command="{Binding BindingContext.NavigateToBookFlightViewCommand, Source={x:Reference flightsCollectionView}}"
                                        CommandParameter="{Binding .}"
                                        TextTransform="Uppercase"
                                        CornerRadius="10"
                                        FontFamily="RobotoBold"
                                        Text="{x:Static resx:AppResource.BookTicket}"
                                        TextColor="White"/>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </views:BasePage.PageContent>

</views:BasePage>
